# Supabase — copie estes valores do painel do Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Service Role key — usada APENAS no servidor (server actions, API routes).
# NUNCA prefixar com NEXT_PUBLIC_. Mantenha em segredo.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# (Opcional) Token de fallback para acesso administrativo via header simples.
# Útil para scripts/exportação. Se vazio, apenas Supabase Auth é aceito.
ADMIN_TOKEN=
